{
  "name": "ts",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@types/bs58": "=5.0.0",
    "prettier": "=3.6.2",
    "turbo": "=2.5.8",
    "typescript": "5.9.2",
    "web": "workspace:0.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.19",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@heroicons/react": "=2.2.0",
    "@radix-ui/react-dialog": "=1.1.15"
  },
  "overrides": {
    "@solana/wallet-adapter-react": "=0.15.39"
  }
}
