# Solana RPC endpoint — canonical name is NEXT_PUBLIC_SOLANA_RPC_URL
# (NEXT_PUBLIC_RPC_ENDPOINT is still accepted as a fallback)
NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_USDC_MINT=
NEXT_PUBLIC_BRENT_MINT=
# Optional server-side admin allowlist override.
# For deployed workers, set this in Cloudflare-managed env/secrets instead of wrangler.jsonc.
ADMIN_OVERRIDE_WALLET=
