{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "account_id": "9eb655a86ca1ba777efa7889d7eb93e6",
  "main": ".open-next/worker.js",
  "name": "bunkercash-web",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "bunkercash-web"
    }
  ],
  "vars": {
    "NEXT_PUBLIC_SOLANA_RPC_URL": "https://solana-testnet-rpc.publicnode.com",
    "NEXT_PUBLIC_SOLANA_CLUSTER": "testnet",
    "NEXT_PUBLIC_CLUSTER": "testnet",
    "NEXT_PUBLIC_USDC_MINT": "DCM1oDQRSv9dn4xpZrXuX23yvivoFHSKKF1mjuCEcjdQ",
    "TRUST_CLOUDFLARE_HEADERS": "true",
    "NEXT_PUBLIC_SQUADS_MULTISIG_PUBKEY": "HEzTX4LNQ7cjrXTt1vKXyEZGtc94TKRUc9kWNFexJSGz"
  },
  "kv_namespaces": [
    {
      "binding": "GEOBLOCKING_KV",
      "id": "9abcd5888b5c436fba6f445f8ba68e98",
      "preview_id": "a6f9582a6f8444bea09b37128e00bb17"
    }
  ]
}
