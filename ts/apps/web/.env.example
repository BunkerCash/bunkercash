# Example env for the web app (copy to `.env.local`)

# Solana RPC endpoint (devnet by default)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# USDC mint used for buys on this cluster (devnet default here is "USDC-Dev")
NEXT_PUBLIC_USDC_MINT=Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr

# ---------------------------------------------------------------------------
# Squads V4 governance
# ---------------------------------------------------------------------------
# Set this to the Squads v4 multisig PDA to enable multisig governance.
# Run `rs/scripts/create-squads-v4-multisig.ts` to create one.
#
# Once set:
#   - The vault PDA (index 0) is derived automatically and used as pool.admin
#   - Admin actions (deposit, withdraw, process claims) become Squads proposals
#   - Any multisig member can initiate and auto-approve proposals via the UI
#   - Other members vote at https://devnet.squads.so (or https://app.squads.so on mainnet)
#
NEXT_PUBLIC_SQUADS_MULTISIG_PUBKEY=
